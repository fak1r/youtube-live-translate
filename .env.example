NODE_ENV=development
LOG_LEVEL=info

UPSTREAM_PROXY_URL=
UPSTREAM_PROXY_SS_URL=
UPSTREAM_PROXY_LOCAL_HOST=127.0.0.1
UPSTREAM_PROXY_LOCAL_PORT=11081
UPSTREAM_PROXY_XRAY_PATH=/usr/local/bin/xray
UPSTREAM_PROXY_STARTUP_TIMEOUT_MS=15000

HTTP_PROXY=
HTTPS_PROXY=

YOUTUBE_LIVE_TRANSLATE_ENABLED=true
YOUTUBE_LIVE_TRANSLATE_HOST=127.0.0.1
YOUTUBE_LIVE_TRANSLATE_PORT=32123
YOUTUBE_LIVE_TRANSLATE_MODEL=Xenova/opus-mt-en-ru
YOUTUBE_LIVE_TRANSLATE_TIMEOUT_MS=15000
YOUTUBE_LIVE_TRANSLATE_MODEL_CACHE_DIR=runtime/youtube-live-translate-model-cache
